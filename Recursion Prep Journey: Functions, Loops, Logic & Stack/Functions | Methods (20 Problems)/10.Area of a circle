package recursionPre;

public class Recursion {
	
	public static double areaOfCircle(int r, double pi){
		double AOC = pi *r*r;
		return AOC;
	}

	public static void main(String[] args) {
		int r=7;
		double pi=3.14;
		double res =  areaOfCircle(r, pi);
		System.out.println("Area of Circle is " + "= " +res );
	}

}
