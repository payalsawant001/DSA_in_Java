package recursionPre;

public class Recursion {
	
	public static int maxOfTwo(int a, int b){
		if(a>b) {
			return a;
		}else {
		   return b;	
		}
	}

	public static void main(String[] args) {
		int a=15, b=88;
		int res = maxOfTwo(a,b);
		System.out.println("Maximum Number of "+ a + " and "+b+ " is "+" = " + res);
	}

}
