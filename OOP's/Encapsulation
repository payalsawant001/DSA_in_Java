class Student {

    // private data members
    private String name;
    private int age;

    // Setter methods
    public void setName(String name) {
        this.name = name;
    }

    public void setAge(int age) {
        this.age = age;
    }

    // Getter methods
    public String getName() {
        return name;
    }

    public int getAge() {
        return age;
    }
}

public class Main {
    public static void main(String[] args) {

        Student s = new Student();

        // setting values
        s.setName("Payal");
        s.setAge(22);

        // getting values
        System.out.println(s.getName());
        System.out.println(s.getAge());
    }
}
