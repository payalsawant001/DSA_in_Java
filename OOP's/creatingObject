Student.java

  public class Student{
    //Arguments of student Object
    public int id;
    public String name;
    public int age;
    public String branch;
    //Constructor calling - Parameterized constructor
    public Student(int id, String name, int age, String branch){
        System.out.println("Constructor is called: ");
        this.id = id;
        this.name=name;
        this.age=age;
        this.branch=branch;
    }

    //Methods of student object
    public void Study(){
        System.out.println(name + " is Studying!");
    }
    public void sleep(){
        System.out.println(name + " is Sleeping!");
    }
    public void bunk(){
        System.out.println(name + " is Bunking!");
    }

}
